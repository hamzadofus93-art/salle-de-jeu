{
  "name": "phoenix-snooker-workspace",
  "private": true,
  "packageManager": "npm@11.6.2",
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "start": "restart-app.cmd",
    "dev": "npm --prefix server run dev",
    "client:dev": "npm --prefix client start",
    "build": "npm --prefix client run build",
    "build:vercel": "npm --prefix server run db:generate && npm --prefix client run build",
    "restart": "restart-app.cmd"
  }
}
